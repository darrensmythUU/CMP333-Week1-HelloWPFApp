<Window x:Class="HelloWPFApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HelloWPFApp"
        mc:Ignorable="d"
        Title="Greetings" Height="450" Width="800">
    <Grid x:Name="No_Name">
        <TextBlock HorizontalAlignment="Center" Margin="0,25,0,0" TextWrapping="Wrap" Text="Select a message option and then choose the Display button." 
                   VerticalAlignment="Top" Height="192" Width="332"/>
        <RadioButton x:Name="radioButton1" Content="Hello" HorizontalAlignment="Left" Margin="273,222,0,0" VerticalAlignment="Top"/>
        <RadioButton x:Name="radioButton2" Content="Goodbye" HorizontalAlignment="Left" Margin="466,222,0,0" VerticalAlignment="Top"/>
        <Button Content="Display" HorizontalAlignment="Center" Margin="0,268,0,0" VerticalAlignment="Top"/>

    </Grid>
</Window>
